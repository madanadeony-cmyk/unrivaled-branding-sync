#!/usr/bin/env node
import fs from "fs";
import path from "path";
import { SHOPIFY_STORE, SHOPIFY_TOKEN, SHOPIFY_API_VERSION } from "./config.js";

const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

function ensureDir(p) {
  fs.mkdirSync(p, { recursive: true });
}
   
function nowStamp() {
  const d = new Date();
  return `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, "0")}${String(
    d.getDate()
  ).padStart(2, "0")}`;
}

// Simple REST fetch with small retry on transient issues / 429
async function shopifyFetch(endpoint, method = "GET", body, { retries = 8 } = {}) {
  const url = `https://${SHOPIFY_STORE}/admin/api/${SHOPIFY_API_VERSION}/${endpoint}`;

  let lastErr;
  for (let attempt = 0; attempt <= retries; attempt++) {
    try {
      const res = await fetch(url, {
        method,
        headers: {
          "X-Shopify-Access-Token": SHOPIFY_TOKEN,
          "Content-Type": "application/json",
        },
        body: body ? JSON.stringify(body) : undefined,
      });

      if (res.status === 429 || (res.status >= 500 && res.status <= 599)) {
        const retryAfter = res.headers.get("retry-after");
        const wait = retryAfter ? Number(retryAfter) * 1000 : 500 * (attempt + 1);
        if (attempt >= retries) throw new Error(`Shopify ${res.status}: ${await res.text()}`);
        await sleep(Math.min(wait, 20_000));
        continue;
      }

      if (!res.ok) throw new Error(`Shopify ${res.status}: ${await res.text()}`);
      return await res.json();
    } catch (e) {
      lastErr = e;
      const msg = String(e?.message || "").toLowerCase();
      const transient =
        msg.includes("fetch failed") ||
        msg.includes("socket") ||
        msg.includes("econnreset") ||
        msg.includes("etimedout");

      if (!transient || attempt >= retries) throw e;
      await sleep(Math.min(500 * (attempt + 1), 10_000));
    }
  }
  throw lastErr || new Error("shopifyFetch failed");
}

// Paginates variants via REST
async function fetchAllVariants() {
  // REST limit is 250. We can paginate with since_id using variants.json.
  // Endpoint supports since_id.
  const limit = 250;
  let since_id = 0;
  const out = [];

  while (true) {
    const endpoint = `variants.json?limit=${limit}&since_id=${since_id}`;
    const data = await shopifyFetch(endpoint);
    const batch = data.variants || [];

    if (!batch.length) break;

    out.push(...batch);
    since_id = batch[batch.length - 1].id;

    if (batch.length < limit) break;
  }

  return out;
}

(async () => {
  if (!SHOPIFY_STORE) throw new Error("SHOPIFY_STORE missing");
  if (!SHOPIFY_TOKEN) throw new Error("SHOPIFY_TOKEN missing");

  ensureDir("data");
  ensureDir("logs");

  const stamp = nowStamp();
  const logPath = path.join("logs", `variant-map-${stamp}.jsonl`);
  const writeLog = (obj) => fs.appendFileSync(logPath, JSON.stringify(obj) + "\n", "utf8");

  console.log("🔎 Fetching all Shopify variants (this can take time on big stores)...");
  const variants = await fetchAllVariants();
  console.log(`✅ Got ${variants.length} variants`);

  const map = {};
  let mapped = 0;

  for (const v of variants) {
    const sku = String(v.sku || "").trim();
    if (!sku) continue;

    // If duplicates exist, keep the first and log
    if (!map[sku]) {
      map[sku] = v.id;
      mapped++;
    } else {
      writeLog({ type: "duplicate_sku", sku, kept: map[sku], skipped: v.id });
    }
  }

  fs.writeFileSync("data/variant-map.json", JSON.stringify(map, null, 2), "utf8");

  writeLog({ type: "summary", variants: variants.length, mapped, output: "data/variant-map.json" });

  console.log(`🗺️  Wrote data/variant-map.json with ${mapped} SKU→variantId entries`);
  console.log(`🧾 Log: ${logPath}`);
})().catch((e) => {
  console.error("🔥 Failed:", e?.message || e);
  process.exit(1);
});
